@page "/profile"

<PageTitle>Profile</PageTitle>

<h1>Profile</h1>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Personal info</BbCardTitle>
    </BbCardHeader>
    <BbCardContent class="space-y-4">
        <div class="profile-row">
            <BbAvatar>
                <BbAvatarFallback>DU</BbAvatarFallback>
            </BbAvatar>
            <div>
                <p>Demo User</p>
                <p class="muted">demo@babidi.app</p>
            </div>
        </div>
        <BbSeparator />
        <p>Preferences and change-password sections can be extended from this baseline page.</p>
    </BbCardContent>
</BbCard>
