@page "/settings"

<PageTitle>Settings</PageTitle>

<h1>Settings</h1>

<BbTabs DefaultValue="general">
    <BbTabsList>
        <BbTabsTrigger Value="general">General</BbTabsTrigger>
        <BbTabsTrigger Value="notifications">Notifications</BbTabsTrigger>
    </BbTabsList>
    <BbTabsContent Value="general">
        <BbCard>
            <BbCardContent class="space-y-3">
                <p>Application settings placeholder.</p>
                <BbSwitch @bind-Checked="compactMode" />
                <BbLabel>Compact mode</BbLabel>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>
    <BbTabsContent Value="notifications">
        <BbCard>
            <BbCardContent class="space-y-3">
                <p>Notification preferences placeholder.</p>
                <BbSwitch @bind-Checked="emailNotifications" />
                <BbLabel>Email alerts</BbLabel>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>
</BbTabs>

@code {
    private bool compactMode;
    private bool emailNotifications = true;
}
