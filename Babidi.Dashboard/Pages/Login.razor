@page "/login"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="login-shell">
    <BbCard Class="login-card">
        <BbCardHeader>
            <BbCardTitle>Babidi Dashboard</BbCardTitle>
            <BbCardDescription>Sign in to continue</BbCardDescription>
        </BbCardHeader>
        <BbCardContent class="space-y-4">
            <EditForm Model="this" OnSubmit="LoginAsync">
                <div>
                    <BbLabel For="email">Email</BbLabel>
                    <InputText id="email" class="native-input" @bind-Value="email" />
                </div>
                <div>
                    <BbLabel For="password">Password</BbLabel>
                    <InputText id="password" type="password" class="native-input" @bind-Value="password" />
                </div>
                <div class="remember-row">
                    <InputCheckbox id="remember" @bind-Value="rememberMe" />
                    <BbLabel For="remember">Remember me</BbLabel>
                </div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <p class="error-text">@error</p>
                }
                <BbCardFooter>
                    <button type="submit" class="action-btn">Login</button>
                </BbCardFooter>
            </EditForm>
        </BbCardContent>
    </BbCard>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool rememberMe = true;
    private string? error;

    private async Task LoginAsync(EditContext _)
    {
        if (!await AuthService.LoginAsync(email, password))
        {
            error = "Please provide both email and password.";
            return;
        }

        NavigationManager.NavigateTo("/dashboard");
    }
}
