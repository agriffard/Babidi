@page "/dashboard"

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<div class="stats-grid">
    <BbCard><BbCardHeader><BbCardTitle>Total Users</BbCardTitle></BbCardHeader><BbCardContent>1,248</BbCardContent></BbCard>
    <BbCard><BbCardHeader><BbCardTitle>Revenue</BbCardTitle></BbCardHeader><BbCardContent>$84,320</BbCardContent></BbCard>
    <BbCard><BbCardHeader><BbCardTitle>Active Sessions</BbCardTitle></BbCardHeader><BbCardContent>312</BbCardContent></BbCard>
    <BbCard><BbCardHeader><BbCardTitle>Growth</BbCardTitle></BbCardHeader><BbCardContent><BbBadge Variant="BadgeVariant.Default">+12.4%</BbBadge></BbCardContent></BbCard>
</div>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Activity summary</BbCardTitle>
        <BbCardDescription>Example dashboard panels built with BlazorBlueprint</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <BbSheet>
            <BbSheetTrigger AsChild>
                <BbButton Variant="ButtonVariant.Outline">Open flyout panel</BbButton>
            </BbSheetTrigger>
            <BbSheetContent>
                <BbCardTitle>Quick view</BbCardTitle>
                <p>Review item details and notifications from this reusable flyout panel.</p>
            </BbSheetContent>
        </BbSheet>
    </BbCardContent>
</BbCard>
